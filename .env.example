# ─── Required ─────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-64-char-string
FRONTEND_URL=https://your-app-name.up.railway.app

# ─── Server ───────────────────────────────────────────────
PORT=4000

# ─── PayPal Payment Link ──────────────────────────────────
PAYPAL_PAYMENT_LINK=https://www.paypal.com/ncp/payment/A7G5YBBM3ZJCY

# ─── Self-Custodial Crypto (Solana) ───────────────────────
# Your wallet address for receiving SOL/USDC payments
CRYPTO_WALLET_ADDRESS=
# Solana RPC URL (mainnet or devnet)
CRYPTO_RPC_URL=https://api.mainnet-beta.solana.com
CRYPTO_CURRENCY=SOL
# Minimum amount to accept (in SOL/USDC)
CRYPTO_MIN_AMOUNT=0.04

# ─── Node Environment ─────────────────────────────────────
NODE_ENV=production
